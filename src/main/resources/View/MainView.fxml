<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smt.Controller.MainController"
            stylesheets="@../CSS/theme.css"

        style="-fx-background-color: #1e1e1e;">

        <!-- 顶部菜单栏（深色） -->
<top>
<MenuBar style="-fx-background-color: #252526; -fx-border-color: #333333;">
    <Menu text="File" style="-fx-text-fill: #ffffff;">
        <MenuItem text="open..." fx:id="openFolderMenuItem"/>
    </Menu>
</MenuBar>
</top>

        <!-- 主体三区域布局 -->
<center>
<SplitPane dividerPositions="0.22, 0.75"
           orientation="HORIZONTAL"
           style="-fx-background-color: #1e1e1e; -fx-padding: 0;">

    <!-- 左侧：文件目录树 -->
    <VBox fx:id="explorerVBox" spacing="5"
          style="-fx-background-color: #252526;">
        <Label fx:id="fileTitle" text="Project"
               style="-fx-font-weight: bold; -fx-text-fill: #ffffff; -fx-padding: 10;"/>
        <TreeView fx:id="fileTreeView" VBox.vgrow="ALWAYS"/>
    </VBox>

    <!-- 中间：Monaco 编辑器 -->
    <StackPane fx:id="editorContainer"
               style="-fx-background-color: #1e1e1e;"/>
</SplitPane>
</center>
</BorderPane>