<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="553.0" prefWidth="833.0" style="-fx-background-color: #1e1e1e;" stylesheets="@../CSS/theme.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smt.Controller.MainController">

        <!-- 顶部菜单栏（深色） -->
<top>
    <MenuBar style="-fx-background-color: #252526; -fx-border-color: #333333;">
        <Menu text="File" style="-fx-text-fill: #ffffff;">
            <MenuItem fx:id="openFolderMenuItem" text="open..." />
        </Menu>
    </MenuBar>
</top>

        <!-- 主体三区域布局 -->
<center>
    <SplitPane dividerPositions="0.20, 0.80"
               orientation="HORIZONTAL"
               style="-fx-background-color: #1e1e1e;">

    <!-- 左侧：文件目录树 -->
    <VBox fx:id="explorerVBox" spacing="5" style="-fx-background-color: #252526;">
        <Label fx:id="fileTitle" style="-fx-font-weight: bold; -fx-text-fill: #ffffff; -fx-padding: 10;" text="Project" />
        <TreeView fx:id="fileTreeView" VBox.vgrow="ALWAYS" />
    </VBox>

    <!-- 中间：Monaco 编辑器 -->
    <StackPane fx:id="editorContainer" prefHeight="526.0" prefWidth="414.0" style="-fx-background-color: #1e1e1e;" />
         <VBox prefHeight="526.0" prefWidth="72.0">
            <children>
                <Label style="-fx-font-weight: bold; -fx-text-fill: #ffffff; -fx-padding: 10.0;" text=" Assistant" />
                <TextArea fx:id="chatArea" editable="false" style="-fx-control-inner-background: #1e1e1e;                                  -fx-text-fill: #cccccc;                                  -fx-font-family: 'Consolas', monospace;" wrapText="true" VBox.vgrow="ALWAYS" />
               <HBox prefHeight="100.0" prefWidth="200.0">
                  <children>
                      <VBox spacing="6">
                          <TextArea fx:id="promptField"
                                    promptText="input your query..."
                                    prefRowCount="3"
                                    wrapText="true"
                                    style="-fx-control-inner-background: #3c3c3c;
                                     -fx-text-fill: #ffffff;
                                     -fx-prompt-text-fill: #888888;
                                     -fx-font-family: 'Consolas', monospace;"/>

                          <HBox alignment="CENTER_RIGHT">
                              <Button fx:id="sendButton"
                                      text="发送"
                                      style="-fx-background-color: #007acc;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;"/>
                          </HBox>
                      </VBox>
                  </children>
               </HBox>
            </children>
         </VBox>

</SplitPane>
</center>
</BorderPane>
