<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TabPane?>
<BorderPane prefHeight="553.0" prefWidth="833.0" style="-fx-background-color: #1e1e1e;" stylesheets="@../CSS/theme.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smt.Controller.MainController">

        <!-- 顶部菜单栏（深色） -->
<top>
    <MenuBar >
        <Menu text="File">
            <MenuItem fx:id="openFolderMenuItem" text="open..." />
            <MenuItem fx:id="openSettingMenuItem" text="settings.." />
        </Menu>
    </MenuBar>
</top>
<!-- 主体三区域布局 -->
<center>
    <SplitPane fx:id="mainSplitPane" dividerPositions="0.2, 0.8" orientation="HORIZONTAL" style="-fx-background-color: #1e1e1e;">

    <!-- 左侧：文件目录树 -->
    <VBox fx:id="explorerVBox" spacing="5" style="-fx-background-color: #252526;">
        <Label fx:id="fileTitle" style="-fx-font-weight: bold; -fx-text-fill: #ffffff; -fx-padding: 10;" text="Project" />
        <TreeView fx:id="fileTreeView" VBox.vgrow="ALWAYS" />
    </VBox>

    <!-- 中间：Monaco 编辑器 -->
    <TabPane fx:id="editorContainer" prefHeight="526.0" prefWidth="414.0" style="-fx-background-color: #1e1e1e;" />
    <!-- 右侧：AI助手 -->
        <VBox fx:id="aiView"
              spacing="8"
              style="-fx-background-color: #252526;">

            <!-- 顶部标题 -->
            <Label text="AI Assistant"
                   style="-fx-text-fill: #ffffff;
                  -fx-font-size: 14px;
                  -fx-font-weight: bold;
                  -fx-padding: 10 10 5 10;" />

            <!-- 聊天内容区（核心优化：ScrollPane） -->
            <ScrollPane fitToWidth="true"
                        fitToHeight="true"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background: #1e1e1e;
                       -fx-background-color: transparent;
                       -fx-border-color: transparent;">

                <TextArea fx:id="chatArea"
                          editable="false"
                          wrapText="true"
                          style="-fx-control-inner-background: #1e1e1e;
                         -fx-text-fill: #d4d4d4;
                         -fx-font-family: 'Consolas', monospace;
                         -fx-background-insets: 0;
                         -fx-background-color: transparent;
                         -fx-padding: 10;" />
            </ScrollPane>

            <!-- 输入区域（Cursor风格底部输入栏） -->
            <HBox spacing="6"
                  alignment="CENTER_LEFT"
                  style="-fx-padding: 6;
                 -fx-background-color: transparent;">

                <!-- 输入框 -->
                <TextArea fx:id="promptField"
                          prefRowCount="3"
                          prefWidth="80"
                          wrapText="true"
                          promptText="Ask something..."
                          HBox.hgrow="ALWAYS"
                          style="-fx-control-inner-background: #3c3c3c;
                         -fx-text-fill: #ffffff;
                         -fx-background-color: transparent;
                         -fx-prompt-text-fill: #888888;
                         -fx-background-radius: 8;" />

                <!-- 发送按钮 -->
                <Button fx:id="sendButton"
                        text="➤"
                        prefWidth="40"
                        prefHeight="30"
                        style="-fx-background-color: #007acc;
                       -fx-text-fill: white;
                       -fx-background-radius: 10;
                       -fx-font-size: 14;
                       -fx-cursor: hand;" />
            </HBox>

        </VBox>

</SplitPane>
</center>
</BorderPane>
