<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<BorderPane prefHeight="280" prefWidth="480" style="-fx-background-color: #1e1e1e;"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smt.Controller.ConfigureController">
    <top>
        <HBox fx:id="titleBar"
              alignment="CENTER_LEFT"
              spacing="8"
              style="-fx-background-color: #252526;
                     -fx-padding: 8 12 8 12;
                     -fx-border-color: #3c3c3c;
                     -fx-border-width: 0 0 1 0;">

            <!-- Logo + 标题 -->
            <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <ImageView fx:id="logoImage" fitHeight="26" fitWidth="26" preserveRatio="true">
                    <image>
                        <Image url="@../Img/logo.png" />
                    </image></ImageView>

                <Label fx:id="CoreCreator"
                       text="Configure"
                       style="-fx-text-fill: #ffffff;
                              -fx-font-weight: bold;
                              -fx-font-size: 14px;"/>
            </HBox>

            <Button fx:id="closeButton" style="-fx-background-color: transparent;                                    -fx-text-fill: #cccccc;                                    -fx-font-size: 17px;                                    -fx-cursor: hand;                                    -fx-min-width: 36;                                    -fx-min-height: 32;" styleClass="closeButton" stylesheets="@../CSS/theme.css" text="✕" />
        </HBox>
    </top>
    <center>
        <VBox spacing="15" style="-fx-background-color: #1e1e1e; -fx-padding: 20;">

            <Label text="LLM Params"
                   style="-fx-text-fill: #ffffff; -fx-font-size: 18px; -fx-font-weight: bold;"/>

            <GridPane hgap="15" vgap="12" style="-fx-background-color: #252526; -fx-padding: 15;">
                <columnConstraints>
                    <ColumnConstraints percentWidth="30"/>
                    <ColumnConstraints percentWidth="70"/>
                </columnConstraints>

                <!-- API Key -->
                <Label text="API Key:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                       style="-fx-text-fill: #cccccc;"/>
                <TextField fx:id="apiKeyField" GridPane.rowIndex="0" GridPane.columnIndex="1"
                           style="-fx-background-color: #3c3c3c; -fx-text-fill: #ffffff;"/>
                <!-- LLM Name -->
                <Label text="LLM Name:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                       style="-fx-text-fill: #cccccc;"/>
                <TextField fx:id="llmNameField" GridPane.rowIndex="1" GridPane.columnIndex="1"
                           style="-fx-background-color: #3c3c3c; -fx-text-fill: #ffffff;"/>

                <!-- LLM Base URL -->
                <Label text="LLM URL:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                       style="-fx-text-fill: #cccccc;"/>
                <TextField fx:id="llmUrlField" GridPane.rowIndex="2" GridPane.columnIndex="1"
                           style="-fx-background-color: #3c3c3c; -fx-text-fill: #ffffff;"/>
            </GridPane>

            <!-- 按钮区域 -->
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button text="Cancel" fx:id="cancelButton"
                        style="-fx-background-color: #3c3c3c; -fx-text-fill: white; -fx-pref-width: 80;"/>
                <Button text="Save" fx:id="saveButton"
                        style="-fx-background-color: #007acc; -fx-text-fill: white; -fx-pref-width: 80;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>