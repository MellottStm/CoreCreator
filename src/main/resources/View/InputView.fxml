<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<VBox spacing="15" style="-fx-background-color: #2b2b2b; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.smt.Controller.InputController">

    <Label fx:id="titleLabel"
           text="Title"
           style="-fx-text-fill: white; -fx-font-size: 16;" />

    <TextField fx:id="inputField"
               style="-fx-background-color: #3c3f41; -fx-text-fill: white;" />

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" fx:id="cancelBtn"
                style="-fx-background-color: #555; -fx-text-fill: white;" />
        <Button text="OK" fx:id="okBtn"
                style="-fx-background-color: #007acc; -fx-text-fill: white;" />
    </HBox>

</VBox>
