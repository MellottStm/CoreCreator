<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-background-color: #2b2b2b; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.smt.Controller.ConfirmController">

    <Label fx:id="titleLabel"
           text="Confirm"
           style="-fx-text-fill: white; -fx-font-size: 16;" />

    <Label fx:id="contentLabel"
           text="内容"
           wrapText="true"
           style="-fx-text-fill: #bbbbbb;" />

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" fx:id="cancelBtn"
                style="-fx-background-color: #555; -fx-text-fill: white;" />
        <Button text="OK" fx:id="okBtn"
                style="-fx-background-color: #c75450; -fx-text-fill: white;" />
    </HBox>

</VBox>
