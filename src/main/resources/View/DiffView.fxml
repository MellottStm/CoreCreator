<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.fxmisc.richtext.CodeArea?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.smt.Controller.DiffController"
      style="-fx-background-color: #1e1e1e;"
      spacing="12">

    <HBox fx:id="titleBar"
          alignment="CENTER_LEFT"
          spacing="8"
          style="-fx-background-color: #252526;
                 -fx-padding: 8 12 8 12;
                 -fx-border-color: #3c3c3c;
                 -fx-border-width: 0 0 1 0;">

        <!-- 左侧：Logo + 窗口标题 -->
        <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
            <ImageView fx:id="logoImage"
                       fitHeight="26"
                       fitWidth="26"
                       preserveRatio="true">
                <image>
                    <Image url="@../Img/logo.png" />
                </image>
            </ImageView>

            <Label fx:id="windowTitle"
                   text="CoreCreator"
                   style="-fx-text-fill: #ffffff;
                          -fx-font-weight: bold;
                          -fx-font-size: 14px;"/>
        </HBox>

        <!-- 右侧：窗口控制按钮 -->
        <HBox spacing="4" alignment="CENTER_RIGHT">

            <Button fx:id="minimizeButton" style="-fx-background-color: transparent;                                    -fx-text-fill: #cccccc;                                    -fx-font-size: 17px;                                    -fx-cursor: hand;                                    -fx-min-width: 36;                                    -fx-min-height: 32;" styleClass="minimizeButton" stylesheets="@../CSS/theme.css" text="🗕" />

            <Button fx:id="maximizeButton" style="-fx-background-color: transparent;                                    -fx-text-fill: #cccccc;                                    -fx-font-size: 17px;                                    -fx-cursor: hand;                                    -fx-min-width: 36;                                    -fx-min-height: 32;" styleClass="maximizeButton" stylesheets="@../CSS/theme.css" text="🗖" />

            <Button fx:id="closeButton" style="-fx-background-color: transparent;                                    -fx-text-fill: #cccccc;                                    -fx-font-size: 17px;                                    -fx-cursor: hand;                                    -fx-min-width: 36;                                    -fx-min-height: 32;" styleClass="closeButton" stylesheets="@../CSS/theme.css" text="✕" />
        </HBox>
    </HBox>

    <children>

        <VBox spacing="6" style="-fx-background-color: #252526; -fx-background-radius: 6;">
            <padding>
                <Insets top="8" right="10" bottom="8" left="10"/>
            </padding>

            <Label text="Changed Files"
                   style="-fx-text-fill: #cccccc;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-padding: 2 4;"/>

            <ListView fx:id="fileListView"
                      prefHeight="140"
                      styleClass="custom-list-view" stylesheets="@../CSS/theme.css"
                   />
        </VBox>

        <!-- 分割面板：Original | Modified -->
        <SplitPane dividerPositions="0.5"
                   VBox.vgrow="ALWAYS"
                   style="-fx-background-color: #1e1e1e;
                          -fx-border-color: #3c3c3c;
                          -fx-border-radius: 6;">

            <!-- 左侧：Original -->
            <VBox spacing="6" style="-fx-background-color: #2b2b2b; -fx-background-radius: 6;">
                <padding>
                    <Insets top="8" right="8" bottom="6" left="8"/>
                </padding>
                <Label text="Original"
                       style="-fx-text-fill: #cccccc;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-padding: 4 8;"/>
                <StackPane fx:id="leftContainer"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #1e1e1e;
                                  -fx-background-radius: 4;">
                    <CodeArea fx:id="leftCodeArea"
                              style="-fx-font-family: 'Consolas', 'Monaco', monospace;
                                     -fx-font-size: 13px;"
                              styleClass="code-area"/>
                </StackPane>
            </VBox>

            <!-- 右侧：Modified -->
            <VBox spacing="6" style="-fx-background-color: #2b2b2b; -fx-background-radius: 6;">
                <padding>
                    <Insets top="8" right="8" bottom="6" left="8"/>
                </padding>
                <Label text="Modified"
                       style="-fx-text-fill: #cccccc;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-padding: 4 8;"/>
                <StackPane fx:id="rightContainer"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #1e1e1e;
                                  -fx-background-radius: 4;">
                    <CodeArea fx:id="rightCodeArea"
                              style="-fx-font-family: 'Consolas', 'Monaco', monospace;
                                     -fx-font-size: 13px;"
                              styleClass="code-area"/>
                </StackPane>
            </VBox>
        </SplitPane>

        <!-- 底部按钮区域 -->
        <HBox spacing="15"
              alignment="CENTER_RIGHT"
              style="-fx-padding: 8 8 8 8;">
            <Button fx:id="applyBtn"
                    text="Apply"
                    style="-fx-background-color: #007acc;
                           -fx-text-fill: white;
                           -fx-pref-width: 140;
                           -fx-font-size: 13px;"/>
            <Button fx:id="reverseBtn"
                    text="Reverse"
                    style="-fx-background-color: #3c3c3c;
                           -fx-text-fill: white;
                           -fx-pref-width: 140;
                           -fx-font-size: 13px;"/>
        </HBox>

    </children>
</VBox>